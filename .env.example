MMX_BASE_DIR=.
MMX_TIMEZONE=Asia/Seoul
MMX_PREMIUM_DATE_BASIS=RECOGNIZED_AT

# Reporting delay (Lead reporting delay)
MMX_REPORTING_DELAY=OFF
MMX_REPORTING_DELAY_MAX=3

# Objective
MMX_OBJECTIVE_MODE=RISK_ADJUSTED
MMX_POLICY_LAMBDA=0.8
MMX_POLICY_DELTA=0.15

# Inference
MMX_INFERENCE_BACKEND=PYMC
MMX_INFERENCE_METHOD=VI
MMX_N_SAMPLES=2000

# Ramp-up cap for channels with prev=0
MMX_RAMP_UP_CAP_SHARE=0.05
MMX_RAMP_UP_CAP_ABS=0.0

# Data validation & normalization
MMX_CHANNEL_NORMALIZE=true
# Optional allowlist (comma-separated). Example: google,meta,naver,kakao
MMX_ALLOWED_CHANNELS=
MMX_ENFORCE_CHANNEL_ALLOWLIST=false
MMX_MAX_UNKNOWN_CHANNEL_RATIO=0.0
MMX_MAX_NAT_RATIO=0.001

# Funnel monotonicity gate
MMX_ENFORCE_FUNNEL_MONOTONICITY=false
MMX_MAX_MONOTONIC_VIOLATION_RATIO=0.0
